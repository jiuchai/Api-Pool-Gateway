  "count": 18,
  "services": [
    {
      "slug": "clever-convert",
      "name": "万能文件转换",
      "description": "转换任意文件格式——图片、音频、视频、文档、PDF等，支持143+格式对。上传文件并指定目标格式即可。",
      "category": "convert",
      "targetUrl": "https://cleverutils.com/api/v1/convert",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "file", "type": "file", "required": true, "description": "要转换的源文件，最大200MB" },
        { "name": "to_format", "type": "string", "required": true, "description": "目标格式扩展名，如 png、mp3、pdf、webp" },
        { "name": "img_quality", "type": "number", "required": false, "description": "图片质量 0-100，默认80" }
      ],
      "inputExample": "{\n  \"file\": \"@photo.png\",\n  \"to_format\": \"jpg\",\n  \"img_quality\": 85\n}",
      "outputExample": "{\n  \"data\": {\n    \"job_id\": \"xxx\",\n    \"status\": \"done\",\n    \"output\": {\n      \"filename\": \"photo.jpg\",\n      \"url\": \"https://cleverutils.com/api/v1/jobs/xxx/output\"\n    }\n  }\n}"
    },
    {
      "slug": "clever-upscale",
      "name": "AI图片超分放大",
      "description": "使用Real-ESRGAN AI模型将图片放大2x/3x/4x，提升分辨率的同时增强细节。",
      "category": "ai-image",
      "targetUrl": "https://cleverutils.com/api/v1/tools/upscale-image",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "file", "type": "file", "required": true, "description": "要放大的图片文件" },
        { "name": "scale", "type": "number", "required": false, "description": "放大倍数：2、3 或 4，默认2" }
      ],
      "inputExample": "{\n  \"file\": \"@photo.jpg\",\n  \"scale\": 2\n}",
      "outputExample": "{\n  \"data\": {\n    \"job_id\": \"xxx\",\n    \"status\": \"done\",\n    \"output\": { \"url\": \"https://...\" }\n  }\n}"
    },
