{
  "version": "1.0",
  "source": "Gotenberg (https://gotenberg.dev/)",
  "exportedAt": "2026-07-16T00:00:00Z",
  "note": "Docker部署请将 127.0.0.1:1002 改为 host.docker.internal:1002",
  "count": 6,
  "services": [
    {
      "slug": "gotenberg-html-to-pdf",
      "name": "HTML转PDF",
      "description": "将HTML文件（可附带图片、样式等资源）转换为PDF文档，支持页眉页脚、页面尺寸等自定义设置。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/chromium/convert/html",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "files", "type": "files", "required": true, "description": "HTML文件(index.html)及依赖资源(图片、CSS等)，路径需在根级" },
        { "name": "paperWidth", "type": "number", "required": false, "description": "纸张宽度（英寸），默认8.5" },
        { "name": "paperHeight", "type": "number", "required": false, "description": "纸张高度（英寸），默认11" },
        { "name": "marginTop", "type": "number", "required": false, "description": "上边距（英寸），默认0.39" },
        { "name": "marginBottom", "type": "number", "required": false, "description": "下边距（英寸），默认0.39" },
        { "name": "marginLeft", "type": "number", "required": false, "description": "左边距（英寸），默认0.39" },
        { "name": "marginRight", "type": "number", "required": false, "description": "右边距（英寸），默认0.39" },
        { "name": "landscape", "type": "boolean", "required": false, "description": "是否横向打印，默认false" },
        { "name": "printBackground", "type": "boolean", "required": false, "description": "是否打印背景，默认false" },
        { "name": "scale", "type": "number", "required": false, "description": "页面渲染缩放比例，默认1.0" }
      ],
      "inputExample": "{\n  \"files\": [\"index.html\", \"style.css\", \"logo.png\"],\n  \"paperWidth\": 8.27,\n  \"paperHeight\": 11.7,\n  \"printBackground\": true\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"PDF二进制文件\" }\n}"
    },
    {
      "slug": "gotenberg-url-to-pdf",
      "name": "网页URL转PDF",
      "description": "将任意网页URL转换为PDF文档，支持等待JavaScript渲染、自定义页面尺寸、模拟媒体类型等。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/chromium/convert/url",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "url", "type": "string", "required": true, "description": "要转换的网页URL" },
        { "name": "paperWidth", "type": "number", "required": false, "description": "纸张宽度（英寸），默认8.5" },
        { "name": "paperHeight", "type": "number", "required": false, "description": "纸张高度（英寸），默认11" },
        { "name": "marginTop", "type": "number", "required": false, "description": "上边距（英寸），默认0.39" },
        { "name": "marginBottom", "type": "number", "required": false, "description": "下边距（英寸），默认0.39" },
        { "name": "marginLeft", "type": "number", "required": false, "description": "左边距（英寸），默认0.39" },
        { "name": "marginRight", "type": "number", "required": false, "description": "右边距（英寸），默认0.39" },
        { "name": "landscape", "type": "boolean", "required": false, "description": "是否横向打印，默认false" },
        { "name": "printBackground", "type": "boolean", "required": false, "description": "是否打印背景图形，默认false" },
        { "name": "waitDelay", "type": "string", "required": false, "description": "等待渲染时长，如 '5s'" },
        { "name": "emulatedMediaType", "type": "string", "required": false, "description": "模拟媒体类型: screen 或 print，默认print" }
      ],
      "inputExample": "{\n  \"url\": \"https://example.com\",\n  \"paperWidth\": 8.27,\n  \"paperHeight\": 11.7,\n  \"printBackground\": true\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"PDF二进制文件\" }\n}"
    },
    {
      "slug": "gotenberg-markdown-to-pdf",
      "name": "Markdown转PDF",
      "description": "将Markdown文件转换为排版精美的PDF文档，需提供index.html模板（使用{{ toHTML }}函数）。支持MathJax数学公式。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/chromium/convert/markdown",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "files", "type": "files", "required": true, "description": "index.html模板 和 至少一个 .md 文件" },
        { "name": "paperWidth", "type": "number", "required": false, "description": "纸张宽度（英寸），默认8.5" },
        { "name": "paperHeight", "type": "number", "required": false, "description": "纸张高度（英寸），默认11" },
        { "name": "marginTop", "type": "number", "required": false, "description": "上边距（英寸），默认0.39" },
        { "name": "marginBottom", "type": "number", "required": false, "description": "下边距（英寸），默认0.39" },
        { "name": "landscape", "type": "boolean", "required": false, "description": "是否横向打印，默认false" }
      ],
      "inputExample": "{\n  \"files\": [\"index.html\", \"document.md\"],\n  \"paperWidth\": 8.27,\n  \"paperHeight\": 11.7\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"PDF二进制文件\" }\n}"
    },
    {
      "slug": "gotenberg-office-to-pdf",
      "name": "Office文档转PDF",
      "description": "使用LibreOffice将Office文档（docx/xlsx/pptx/odt/ods/odp等）转换为PDF，保留原始排版。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/libreoffice/convert",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "files", "type": "files", "required": true, "description": "要转换的Office文档（docx/xlsx/pptx/odt/ods/odp等）" },
        { "name": "landscape", "type": "boolean", "required": false, "description": "是否横向打印，默认false" },
        { "name": "nativePageRanges", "type": "string", "required": false, "description": "页码范围，如 '1-5'，默认全部" }
      ],
      "inputExample": "{\n  \"files\": [\"report.docx\"],\n  \"landscape\": false\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"PDF二进制文件\" }\n}"
    },
    {
      "slug": "gotenberg-merge-pdfs",
      "name": "PDF合并",
      "description": "将多个PDF文件按上传顺序合并为一个PDF文档。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/pdfengines/merge",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "files", "type": "files", "required": true, "description": "要合并的PDF文件列表" }
      ],
      "inputExample": "{\n  \"files\": [\"part1.pdf\", \"part2.pdf\", \"part3.pdf\"]\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"合并后的PDF文件\" }\n}"
    },
    {
      "slug": "gotenberg-split-pdf",
      "name": "PDF拆分",
      "description": "将PDF文档按指定页码范围拆分为多个PDF文件。",
      "category": "document",
      "targetUrl": "https://develop.musland.top/forms/pdfengines/split",
      "method": "POST",
      "forwardType": "form-data",
      "params": [
        { "name": "files", "type": "file", "required": true, "description": "要拆分的PDF文件" },
        { "name": "splitMode", "type": "string", "required": false, "description": "拆分模式: intervals | pages，默认 intervals" },
        { "name": "splitIntervals", "type": "string", "required": false, "description": "拆分为多组页码范围，如 '1-3,4-6'，每组输出一个PDF" },
        { "name": "splitUnify", "type": "boolean", "required": false, "description": "是否合并指定范围，如 '1-3,6-9' 作为整体输出一个PDF" }
      ],
      "inputExample": "{\n  \"file\": \"large_document.pdf\",\n  \"splitIntervals\": \"1-5,6-10\"\n}",
      "outputExample": "{\n  \"success\": true,\n  \"data\": { \"file\": \"拆分后的PDF文件\" }\n}"
    }
  ]
}
