{
  "name": "api-pool-gateway",
  "version": "1.0.0",
  "description": "动态API聚合网关 - 支持热加载多种API服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "frontend": "cd frontend && npx vite --host",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"node server.js\" \"cd frontend && npx vite --host\"",
    "pay-server": "node payserver-dome/server.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "svg-captcha": "^1.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
