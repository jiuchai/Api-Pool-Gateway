# 服务监听端口（容器内部）
PORT=3000
# JWT 签名密钥
JWT_SECRET=change-me
# 管理员用户名
ADMIN_USERNAME=admin
# 管理员邮箱
ADMIN_EMAIL=admin@pool.com
# 管理员密码
ADMIN_PASSWORD=change-me
# 超级管理员密码（忘记密码时临时启用，使用后请关闭）
# MASTER_PASSWORD_ENABLED=false
# MASTER_PASSWORD=SuperAdmin@123
# 是否重新打包前端，默认 false 使用 public/ 预构建静态文件，设为 true 则从源码构建
BUILD_FRONTEND=false
# Nginx 对外端口，通过 nginx 反向代理访问服务和 API
NGINX_PORT=8080
# MongoDB 连接地址，留空则使用 Docker 内置的 mongodb://mongo:27017/pool-gateway
MONGO_URI=
